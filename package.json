{
  "name": "bb-cli",
  "version": "0.1.0",
  "description": "A lightweight Bitbucket CLI that mirrors glab's UX",
  "type": "module",
  "bin": {
    "bb": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "link": "npm run build && npm link"
  },
  "keywords": [
    "bitbucket",
    "cli",
    "pull-request",
    "pipeline",
    "code-review",
    "devops"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ganeshgaxy/bb-cli.git"
  },
  "homepage": "https://github.com/ganeshgaxy/bb-cli#readme",
  "bugs": {
    "url": "https://github.com/ganeshgaxy/bb-cli/issues"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
